{
  "version": 2,
  "public": true,
  "builds": [{ "src": "**/*", "use": "@vercel/static" }],
  "routes": [{ "src": "/(.*)", "dest": "/$1" }],
  "headers": [
    {
      "source": "/(.*\\.xml)",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    }
  ]
}
